# Shopify Configuration
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_PASSWORD=your_api_password_here
SHOPIFY_API_VERSION=2024-01

# Google Analytics 4 Configuration
GA4_PROPERTY_ID=your_property_id_here
GA4_SERVICE_ACCOUNT_JSON_PATH=./config/ga4-service-account.json

# DataForSEO Configuration
DATASEO_API_KEY=your_dataseo_api_key_here
DATASEO_API_USERNAME=your_dataseo_username_here

# Email Configuration
EMAIL_SERVICE=gmail  # or mailgun, sendgrid
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your_app_password_here  # Gmail app-specific password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# MCP Server Configuration
MCP_SERVER_PORT=5000
MCP_SERVER_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/mcp-server.log

# Vault Configuration (path to your Shopify Brain)
VAULT_PATH=/path/to/your/Shopify\ Brain
